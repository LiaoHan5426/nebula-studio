#!/usr/bin/env sh
set -e

root="$(cd "$(dirname "$0")/.." && pwd)"
cd "$root"

node_major() {
  node -p "Number(process.versions.node.split('.')[0])" 2>/dev/null || echo 0
}

if [ "$(node_major)" -lt 22 ]; then
  if [ -n "${VP_HOME:-}" ] && [ -x "$VP_HOME/bin/node" ]; then
    export PATH="$VP_HOME/bin:$PATH"
  fi
fi

if [ "$(node_major)" -lt 22 ]; then
  echo "VITE+ - pre-commit requires Node.js >= 22.12 (current: $(node -v 2>/dev/null || echo unknown))"
  echo "VITE+ - Run: nvm use   (see .nvmrc)  or set VP_HOME to a VitePlus install"
  exit 1
fi

exec vp staged "$@"

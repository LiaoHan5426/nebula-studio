{
  "extends": "@nebula-studio-internal/tsconfig/web.json",
  "include": [
    "index.html",
    "src/env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "__tests__/**/*",
    "vite.integrationProxy.ts"
  ],
  "compilerOptions": {
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}

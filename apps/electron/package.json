{
  "name": "@nebula-studio/electron",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "Liao Han <liaohan5426@gmail.com>",
  "scripts": {
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.renderer.json --composite false",
    "typecheck:renderers": "vp run --filter \"@nebula-studio-renderer/*\" typecheck",
    "typecheck": "vp run typecheck:node && vp run typecheck:web && vp run typecheck:renderers",
    "start": "vp exec electron-vite preview",
    "dev": "vp exec electron-vite dev",
    "build": "vp run typecheck && vp exec electron-vite build && vp run --filter @nebula-studio-renderer/docs build && node ./scripts/copy-docs-site.mjs",
    "postinstall": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ node ./scripts/ensure-electron.mjs && electron-builder install-app-deps",
    "build:unpack": "vp run build && vp exec electron-builder --dir",
    "pack:win": "vp run build && vp exec electron-builder --win",
    "pack:mac": "vp run build && vp exec electron-builder --mac",
    "pack:linux": "vp run build && vp exec electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "catalog:electron",
    "@electron-toolkit/utils": "catalog:electron",
    "@nebula-studio-electron/electron-shared": "workspace:^",
    "@nebula-studio/app-shell": "workspace:^",
    "electron-updater": "^6.8.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@nebula-studio-internal/node": "workspace:^",
    "@nebula-studio-internal/tailwind": "workspace:^",
    "@nebula-studio-internal/tsconfig": "workspace:^",
    "@nebula-studio-internal/vite": "workspace:^",
    "@nebula-studio-preload/docs": "workspace:^",
    "@nebula-studio-preload/main": "workspace:^",
    "@nebula-studio-preload/settings": "workspace:^",
    "@nebula-studio-renderer/main": "workspace:^",
    "@nebula-studio/types": "workspace:^",
    "@types/node": "catalog:types",
    "electron": "catalog:electron",
    "electron-builder": "catalog:electron",
    "electron-vite": "catalog:electron",
    "typescript": "catalog:types",
    "vite": "catalog:vite",
    "vue": "catalog:vue",
    "vue-tsc": "catalog:vue"
  }
}

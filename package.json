{
  "name": "nebula-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "build": "vp run -r build",
    "build:unpack": "vp run electron#build:unpack",
    "pack:win": "vp run electron#pack:win",
    "pack:mac": "vp run electron#pack:mac",
    "pack:linux": "vp run electron#pack:linux",
    "dev": "vp run electron#dev",
    "start": "vp run electron#start",
    "dev:electron": "vp run electron#dev",
    "sync:app-config": "vp exec esno ./scripts/tasks/sync-app-config.ts",
    "cap": "vp run mobile#cap",
    "check": "vp check --fix",
    "lint": "vp lint --fix",
    "test": "vp run -r test",
    "postinstall": "vp run -r stub --if-present",
    "prepare": "vp config",
    "update:deps": "npx taze -r -w"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:lint",
    "@nebula-studio-internal/oxfmt": "workspace:^",
    "@nebula-studio-internal/oxlint": "workspace:^",
    "@nebula-studio-internal/stylelint": "workspace:^",
    "@nebula-studio-internal/tsconfig": "workspace:^",
    "@vitejs/plugin-vue": "catalog:vite",
    "@vitejs/plugin-vue-jsx": "catalog:vite",
    "eslint-plugin-better-tailwindcss": "catalog:lint",
    "eslint-plugin-command": "catalog:lint",
    "esno": "catalog:",
    "happy-dom": "catalog:vite",
    "tailwindcss": "catalog:style",
    "unconfig": "catalog:",
    "vite-plus": "catalog:vite",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.20"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2"
}

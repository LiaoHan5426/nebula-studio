{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "nebula-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint --threads 2 && vp run test && vp run build",
    "build": "vp run -r build",
    "build:unpack": "vp run electron#build:unpack",
    "pack:win": "vp run electron#pack:win",
    "pack:mac": "vp run electron#pack:mac",
    "pack:linux": "vp run electron#pack:linux",
    "dev": "vp run electron#dev",
    "start": "vp run electron#start",
    "dev:electron": "vp run electron#dev",
    "dev:web": "vp run web#dev",
    "build:web": "vp run web#build",
    "check:bundle": "node ./scripts/check-bundle-budget.mjs",
    "cap": "vp run mobile#cap",
    "check": "vp check --fix",
    "lint:ox": "vp lint --fix --threads=2",
    "lint:style": "vp exec stylelint \"**/*.{css,scss,vue}\" --fix --allow-empty-input --ignore-pattern \"**/out/**\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/dev-dist/**\"",
    "lint": "vp run lint:ox && vp run lint:style",
    "test": "vp run -r test",
    "test:e2e": "playwright test",
    "test:all": "vp run -r test && playwright test",
    "postinstall": "vp run -r stub --if-present",
    "prepare": "vp config",
    "update:deps": "vp dlx taze -r -w",
    "clean": "node ./scripts/clean.mjs",
    "generate:configs": "node ./scripts/generate-window-configs.mjs",
    "generate:manifest": "node ./scripts/generate-window-configs.mjs",
    "generate:contracts": "node ./scripts/generate-contracts.mjs"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:lint",
    "@nebula-studio-internal/oxfmt": "workspace:^",
    "@nebula-studio-internal/oxlint": "workspace:^",
    "@nebula-studio-internal/stylelint": "workspace:^",
    "@nebula-studio-internal/tsconfig": "workspace:^",
    "@nebula-studio/types": "workspace:^",
    "@playwright/test": "catalog:test",
    "@vitejs/plugin-vue": "catalog:vite",
    "@vitejs/plugin-vue-jsx": "catalog:vite",
    "ajv": "catalog:",
    "cross-env": "catalog:utils",
    "eslint-plugin-better-tailwindcss": "catalog:lint",
    "eslint-plugin-command": "catalog:lint",
    "esno": "catalog:utils",
    "happy-dom": "catalog:vite",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "catalog:style",
    "unconfig": "catalog:utils",
    "vite-plus": "catalog:vite",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.1"
}

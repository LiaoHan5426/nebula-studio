{
  "name": "@nebula-studio/nebula-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles.css",
    "./src/index.ts"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "vp test run"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./utils/highlightNebula": {
      "types": "./src/utils/highlightNebula.ts",
      "default": "./src/utils/highlightNebula.ts"
    },
    "./env": {
      "types": "./env.d.ts",
      "default": "./env.d.ts"
    },
    "./styles.css": {
      "default": "./src/styles.css"
    }
  },
  "dependencies": {
    "@iconify/vue": "catalog:ui",
    "@iconify-json/lucide": "catalog:ui",
    "@vueuse/core": "catalog:vue",
    "class-variance-authority": "catalog:ui-utils",
    "clsx": "catalog:ui-utils",
    "reka-ui": "catalog:ui",
    "tailwind-merge": "catalog:ui-utils",
    "vee-validate": "catalog:form",
    "vue": "catalog:vue",
    "vuedraggable": "catalog:ui",
    "vxe-table": "catalog:ui",
    "xe-utils": "catalog:ui"
  },
  "devDependencies": {
    "@nebula-studio-internal/tsconfig": "workspace:^",
    "@nebula-studio/types": "workspace:^",
    "@vue/test-utils": "catalog:vue",
    "sass": "catalog:style"
  }
}

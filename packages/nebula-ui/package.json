{
  "name": "@nebula-studio/nebula-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles.css",
    "./src/utils/highlightNebula.ts",
    "./src/index.ts"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./utils/highlightNebula": {
      "types": "./src/utils/highlightNebula.ts",
      "default": "./src/utils/highlightNebula.ts"
    },
    "./env": {
      "types": "./env.d.ts",
      "default": "./env.d.ts"
    }
  },
  "dependencies": {
    "@codemirror/commands": "catalog:",
    "@codemirror/lang-html": "catalog:",
    "@codemirror/lang-java": "catalog:",
    "@codemirror/lang-javascript": "catalog:",
    "@codemirror/lang-markdown": "catalog:",
    "@codemirror/lang-python": "catalog:",
    "@codemirror/language": "catalog:",
    "@codemirror/state": "catalog:",
    "@codemirror/theme-one-dark": "catalog:",
    "@codemirror/view": "catalog:",
    "@wangeditor-next/editor": "catalog:",
    "@wangeditor-next/editor-for-vue": "catalog:",
    "codemirror": "catalog:",
    "highlight.js": "catalog:",
    "marked": "catalog:",
    "vue": "catalog:vue",
    "vuedraggable": "^4.1.0",
    "vxe-table": "catalog:",
    "xe-utils": "catalog:"
  },
  "devDependencies": {
    "@nebula-studio-internal/tsconfig": "workspace:^",
    "@nebula-studio/types": "workspace:^",
    "sass": "catalog:style"
  }
}
